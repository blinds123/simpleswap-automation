# Steel.dev Browser Credentials (https://steel.dev)
# Get your API key at: https://app.steel.dev
STEEL_API_KEY=your_steel_api_key_here

# Merchant Wallet (Polygon address to receive crypto)
MERCHANT_WALLET=0x1372Ad41B513b9d6eC008086C03d69C635bAE578

# ============================================================================
# PRICE POINTS CONFIGURATION (REQUIRED)
# ============================================================================
# Comma-separated USD amounts for exchange pools
# Each price point will have its own pool of exchanges
# Example: PRICE_POINTS=25,35,50 creates 3 pools
PRICE_POINTS=25

# Pool Configuration (per price point)
POOL_SIZE_PER_PRICE=5
MIN_POOL_SIZE=3

# CORS - Allowed frontend origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500

# Server
PORT=3000
NODE_ENV=production
